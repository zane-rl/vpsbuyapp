// VPS 采购与 VPN 节点管理系统 数据模型
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// VPS 提供商（单独维护，仅名称）
model Provider {
  id         String      @id @default(cuid())
  name       String      @unique
  vpsServers VpsServer[]
  createdAt  DateTime    @default(now())
}

/// 客户（VPS 与收款均归属客户，按客户结算）
model Customer {
  id         String             @id @default(cuid())
  name       String             @unique
  note       String?
  vpsServers VpsServer[]
  payments   CustomerPayment[]
  recharges  CustomerRecharge[]
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
}

/// 客户充值记录（客户级共享余额：名下所有自动续费 VPS 共用）
/// 充值美元计入总成本、实付人民币计入总实付/差额；当前共享余额取最近一条的 balanceAfter
model CustomerRecharge {
  id           String   @id @default(cuid())
  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId   String
  amountUsd    Float    @default(0) // 本次充值（USD，计入总成本）
  paidCny      Float    @default(0) // 本次实际付款（CNY，计入总实付/差额）
  balanceAfter Float    @default(0) // 充值后服务商实际余额（USD），当前余额取最近一条
  rechargeDate DateTime @default(now()) // 充值时间
  paymentProof String? // 付款截图（data/uploads 下的文件名）
  note         String?
  createdAt    DateTime @default(now())

  @@index([customerId])
}

/// 客户收款记录（独立台账：一笔付款可对应多台 VPS，可多次付款）
model CustomerPayment {
  id         String   @id @default(cuid())
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId String
  amountCny    Float    @default(0) // 本次收款金额（CNY）
  payDate      DateTime @default(now()) // 收款时间
  paymentProof String? // 实际收款截图（data/uploads 下的文件名）
  note         String? // 备注（如：付款方式、覆盖哪些 VPS）
  createdAt    DateTime @default(now())

  @@index([customerId])
}

/// VPS 服务器
model VpsServer {
  id String @id @default(cuid())

  name String // 备注名/标识，如 "香港-01"

  // 归属客户 / 提供商（从各自维护的列表中选择）
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerId String?
  provider   Provider? @relation(fields: [providerId], references: [id], onDelete: SetNull)
  providerId String?

  // 计费类型：term=固定期限（有到期时间）/ auto=自动续费（无固定到期，余额由所属客户共享充值）
  billingType   String  @default("term")
  termPeriod    String? // 仅 term：monthly / quarterly / yearly（购买周期，用于推算到期）
  autoCycle     String? // 仅 auto：hourly / monthly / quarterly / yearly
  cyclePriceUsd Float?  // 仅 auto：周期费用（USD，仅展示）
  balanceAmount Float?  // 已弃用：余额改为客户级共享（CustomerRecharge），保留列避免线上重建表

  // 配置信息
  cpu       String?
  ram       String?
  disk      String?
  bandwidth String?
  region    String?
  ipAddress String?
  os        String?

  purchaseDate DateTime // 购买时间
  expiryDate   DateTime? // 到期时间（term 必填，auto 为空；续费时更新为最新到期时间）

  // 采购花费（你的成本；客户收款已移到 CustomerPayment 台账）
  purchaseCostUsd Float @default(0) // 采购成本（USD 标价）
  purchasePaidCny Float @default(0) // 购买实际付款（CNY）

  paymentProof String? // 实际付款截图（data/uploads 下的文件名）

  status String  @default("active") // 运行状态：active / stopped
  notes  String?

  renewals    VpsRenewal[]
  vpnNodes    VpnNode[]
  balanceLogs VpsBalanceLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([expiryDate])
  @@index([customerId])
  @@index([providerId])
}

/// 已弃用：自动续费余额改为客户级共享（见 CustomerRecharge）。保留模型避免线上重建表，应用层不再引用。
model VpsBalanceLog {
  id    String    @id @default(cuid())
  vps   VpsServer @relation(fields: [vpsId], references: [id], onDelete: Cascade)
  vpsId String

  logDate      DateTime @default(now()) // 操作时间
  topupUsd     Float    @default(0) // 本次充值（USD）
  paidCny      Float    @default(0) // 本次实际付款（CNY）
  balanceAfter Float    @default(0) // 更新后余额（USD）
  paymentProof String? // 付款截图（data/uploads 下的文件名）
  note         String?
  createdAt    DateTime @default(now())

  @@index([vpsId])
}

/// 续费记录
model VpsRenewal {
  id    String    @id @default(cuid())
  vps   VpsServer @relation(fields: [vpsId], references: [id], onDelete: Cascade)
  vpsId String

  renewDate      DateTime @default(now()) // 续费操作时间
  previousExpiry DateTime // 续费前到期时间（留档）
  newExpiry      DateTime // 续费后到期时间

  costUsd Float @default(0) // 续费成本（USD）
  paidCny Float @default(0) // 续费实际付款（CNY）

  paymentProof String? // 本次续费付款截图（data/uploads 下的文件名）

  notes     String?
  createdAt DateTime @default(now())

  @@index([vpsId])
}

/// VPN 节点（归属对应 VPS）
model VpnNode {
  id    String    @id @default(cuid())
  vps   VpsServer @relation(fields: [vpsId], references: [id], onDelete: Cascade)
  vpsId String

  name         String
  protocol     String
  address      String?
  port         Int?
  config       String?
  subscribeUrl String? // 订阅链接
  enabled      Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([vpsId])
}
